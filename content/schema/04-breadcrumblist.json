{
  "$comment": "BreadcrumbList template. Every page on the site emits an instance of this shape. Position starts at 1 (Home). Only breadcrumbs actually visible on the page belong in the list. See the four ready-to-use examples below.",
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "@id": "{{PAGE_URL}}#breadcrumb",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "{{CRUMB_1_NAME}}",
      "item": "{{CRUMB_1_URL}}"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "{{CRUMB_2_NAME}}",
      "item": "{{CRUMB_2_URL}}"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": "{{CRUMB_3_NAME}}",
      "item": "{{CRUMB_3_URL}}"
    }
  ],
  "examples": {
    "home": {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "@id": "https://podcastnetwork.org/#breadcrumb",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "https://podcastnetwork.org/"
        }
      ]
    },
    "the-package": {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "@id": "https://podcastnetwork.org/the-package/#breadcrumb",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "https://podcastnetwork.org/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "The Pre-Sold Author Package",
          "item": "https://podcastnetwork.org/the-package/"
        }
      ]
    },
    "case-study-detail": {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "@id": "https://podcastnetwork.org/case-studies/ai-or-die/#breadcrumb",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "https://podcastnetwork.org/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Case Studies",
          "item": "https://podcastnetwork.org/case-studies/"
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": "AI or Die",
          "item": "https://podcastnetwork.org/case-studies/ai-or-die/"
        }
      ]
    },
    "journal-article": {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "@id": "https://podcastnetwork.org/journal/why-six-months/#breadcrumb",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "https://podcastnetwork.org/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Journal",
          "item": "https://podcastnetwork.org/journal/"
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": "Why six months, not eighteen",
          "item": "https://podcastnetwork.org/journal/why-six-months/"
        }
      ]
    }
  }
}

          "addressRegion": "FL",
          "addressCountry": "US"
        }
      },
      "performer": [
        { "@id": "https://podcastnetwork.org/about/#brett-k-moore" },
        { "@id": "https://podcastnetwork.org/about/#mike-partners" }
      ],
      "organizer": {
        "@type": "Organization",
        "name": "eXp Realty",
        "url": "https://exprealty.com/"
      },
      "workPerformed": {
        "@type": "CreativeWork",
        "name": "AI or Die: how the operator layer changes when the LLM becomes a colleague",

        { "@type": "Person", "@id": "https://podcastnetwork.org/about/#mike-partners", "name": "Mike Partners", "$comment_hydrate_from": "11-person-mike.json" },
        {
          "@type": "Book",
          "@id": "https://podcastnetwork.org/book/#book",
          "name": "AI or Die",
          "author": [
            { "@id": "https://podcastnetwork.org/about/#brett-k-moore" },
            { "@id": "https://podcastnetwork.org/about/#mike-partners" }
          ],
          "publisher": { "@type": "Organization", "name": "Legacy Publishing", "url": "https://legacypublishing.com/" },
          "$comment_hydrate_from": "06-book.json"
        },
        {
          "@type": "PodcastSeries",
          "@id": "https://podcastnetwork.org/podcast/#series",
          "name": "{{PODCAST_NAME}}",
          "author": [
            { "@id": "https://podcastnetwork.org/about/#brett-k-moore" },
            { "@id": "https://podcastnetwork.org/about/#mike-partners" }
          ],
          "publisher": { "@id": "https://podcastnetwork.org/#organization" },
          "$comment_hydrate_from": "07-podcastseries.json"
        },
        {
          "@type": "Review",
          "@id": "https://podcastnetwork.org/case-studies/ai-or-die/#review-legacy-publishing",
          "itemReviewed": { "@id": "https://podcastnetwork.org/the-package/#service" },
          "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5", "worstRating": "1" },
          "author": { "@type": "Person", "name": "{{LEGACY_PARTNER_NAME}}", "worksFor": { "@type": "Organization", "name": "Legacy Publishing" } },
          "reviewBody": "{{REVIEW_BODY}}",
          "datePublished": "{{DATE_PUBLISHED_ISO_8601}}",
          "$comment_hydrate_from": "13-review.json"
        },
        {
          "@type": "BreadcrumbList",
          "@id": "https://podcastnetwork.org/case-studies/ai-or-die/#breadcrumb",
          "itemListElement": [
            { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://podcastnetwork.org/" },
            { "@type": "ListItem", "position": 2, "name": "Case Studies", "item": "https://podcastnetwork.org/case-studies/" },
            { "@type": "ListItem", "position": 3, "name": "AI or Die", "item": "https://podcastnetwork.org/case-studies/ai-or-die/" }
          ]
        }
      ]
    },

    "case-study-detail-in-launch-author": {

        },
        {
          "@type": "BreadcrumbList",
          "@id": "https://podcastnetwork.org/the-method/#breadcrumb",
          "itemListElement": [
            { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://podcastnetwork.org/" },
            { "@type": "ListItem", "position": 2, "name": "The Method", "item": "https://podcastnetwork.org/the-method/" }
          ]

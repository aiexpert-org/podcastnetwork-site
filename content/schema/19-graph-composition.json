    "case-study-detail-ai-or-die": {
      "$route": "/case-studies/ai-or-die/",
      "$entities_included": ["Organization", "Person (Brett)", "Person (Mike)", "Book", "PodcastSeries", "Review", "BreadcrumbList", "WebPage"],
      "@context": "https://schema.org",
      "@graph": [
        { "@type": "Organization", "@id": "https://podcastnetwork.org/#organization" },

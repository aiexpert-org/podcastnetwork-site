        },
        {
          "@type": "PodcastSeries",
          "@id": "https://podcastnetwork.org/network/{{AUTHOR_PODCAST_SLUG}}/#series",
          "name": "{{AUTHOR_PODCAST_NAME}}",
          "author": { "@id": "https://podcastnetwork.org/case-studies/{{AUTHOR_SLUG}}/#person" },
          "publisher": { "@id": "https://podcastnetwork.org/#organization" },
          "$comment_hydrate_from": "07-podcastseries.json"
        },
        {
          "@type": "BreadcrumbList",
          "@id": "https://podcastnetwork.org/case-studies/{{AUTHOR_SLUG}}/#breadcrumb",
          "itemListElement": [
            { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://podcastnetwork.org/" },
            { "@type": "ListItem", "position": 2, "name": "Case Studies", "item": "https://podcastnetwork.org/case-studies/" },
            { "@type": "ListItem", "position": 3, "name": "{{AUTHOR_FULL_NAME}}", "item": "https://podcastnetwork.org/case-studies/{{AUTHOR_SLUG}}/" }
          ]
        }
      ]
    },


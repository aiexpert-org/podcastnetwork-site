{
  "$comment": "The composed @graph patterns. Every URL on podcastnetwork.org gets exactly ONE JSON-LD script tag that emits an @context + @graph with all entities relevant to that page. Cross-entity references use @id (never inline duplication). This file is the ground-truth composition reference. When you generate a page, look up the page type here, hydrate the placeholders, and emit the resulting @graph as-is. Every graph has been syntax-checked. No missing commas, no unclosed braces, no dangling @id references. This is the anti-pattern to Kalicube's broken patent portfolio @graph.",
  "$graphs": {
    "homepage": {
      "$route": "/",
      "$entities_included": ["Organization", "WebSite", "ProfessionalService", "BreadcrumbList", "FAQPage (short-list rendition)"],
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Organization",
          "@id": "https://podcastnetwork.org/#organization",
          "name": "PodcastNetwork.org",
          "url": "https://podcastnetwork.org/",
          "logo": { "@id": "https://podcastnetwork.org/#logo" },
          "founder": [
            { "@id": "https://podcastnetwork.org/about/#brett-k-moore" },
            { "@id": "https://podcastnetwork.org/about/#mike-partners" }
          ],
          "sameAs": [
            "https://www.linkedin.com/company/podcastnetworkorg/",
            "https://x.com/podcastnetwork",
            "https://www.wikidata.org/wiki/{{WIKIDATA_Q_NUMBER_ORG}}"
          ],
          "$comment_hydrate_from": "01-organization.json"
        },
        {
          "@type": "ImageObject",
          "@id": "https://podcastnetwork.org/#logo",
          "url": "https://podcastnetwork.org/brand/logo-primary.png",
          "width": 1200,
          "height": 1200
        },
        {
          "@type": "WebSite",
          "@id": "https://podcastnetwork.org/#website",
          "url": "https://podcastnetwork.org/",
          "name": "PodcastNetwork.org",
          "publisher": { "@id": "https://podcastnetwork.org/#organization" },
          "potentialAction": {
            "@type": "SearchAction",
            "target": { "@type": "EntryPoint", "urlTemplate": "https://podcastnetwork.org/search/?q={search_term_string}" },
            "query-input": "required name=search_term_string"
          },
          "$comment_hydrate_from": "02-website-searchaction.json"
        },
        {
          "@type": "WebPage",
          "@id": "https://podcastnetwork.org/#webpage",
          "url": "https://podcastnetwork.org/",
          "name": "PodcastNetwork.org: the premium authority launch, delivered in six months",
          "isPartOf": { "@id": "https://podcastnetwork.org/#website" },
          "primaryImageOfPage": { "@id": "https://podcastnetwork.org/#logo" },
          "breadcrumb": { "@id": "https://podcastnetwork.org/#breadcrumb" },
          "about": { "@id": "https://podcastnetwork.org/the-package/#service" },
          "inLanguage": "en-US"
        },
        {
          "@type": "BreadcrumbList",
          "@id": "https://podcastnetwork.org/#breadcrumb",
          "itemListElement": [
            { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://podcastnetwork.org/" }
          ]
        },
        {
          "@type": "ProfessionalService",
          "@id": "https://podcastnetwork.org/the-package/#service",
          "name": "Pre-Sold Author Package",
          "provider": { "@id": "https://podcastnetwork.org/#organization" },
          "offers": { "@id": "https://podcastnetwork.org/the-package/#offer" },
          "$comment_hydrate_from": "03-professionalservice.json"
        },
        {
          "@type": "FAQPage",
          "@id": "https://podcastnetwork.org/#faq-homepage",
          "mainEntity": [
            { "@id": "https://podcastnetwork.org/faq/#what-does-30k-cover" },
            { "@id": "https://podcastnetwork.org/faq/#manuscript-in-hand" },
            { "@id": "https://podcastnetwork.org/faq/#do-you-take-all-applicants" },
            { "@id": "https://podcastnetwork.org/faq/#no-podcast-yet" },
            { "@id": "https://podcastnetwork.org/faq/#legacy-jv" },
            { "@id": "https://podcastnetwork.org/faq/#versus-diy" }
          ],
          "$comment": "Homepage renders the short-list six questions. Full 20-item FAQPage lives on /faq/. Both reference the same @id URLs so the QA entities are shared, not duplicated."
        }
      ]
    },

    "the-package": {
      "$route": "/the-package/",
      "$entities_included": ["Organization", "ProfessionalService", "Offer", "FAQPage", "BreadcrumbList", "WebPage"],
      "@context": "https://schema.org",
      "@graph": [
        { "@type": "Organization", "@id": "https://podcastnetwork.org/#organization", "name": "PodcastNetwork.org", "url": "https://podcastnetwork.org/" },
        {
          "@type": "ProfessionalService",
          "@id": "https://podcastnetwork.org/the-package/#service",
          "name": "Pre-Sold Author Package",
          "url": "https://podcastnetwork.org/the-package/",
          "description": "One package. One price. $30,000. Six months. Four pillars.",
          "provider": { "@id": "https://podcastnetwork.org/#organization" },
          "offers": { "@id": "https://podcastnetwork.org/the-package/#offer" },
          "hasOfferCatalog": { "@id": "https://podcastnetwork.org/the-package/#catalog" },
          "aggregateRating": { "@id": "https://podcastnetwork.org/the-package/#rating" },
          "$comment_hydrate_from": "03-professionalservice.json"
        },
        {
          "@type": "Offer",
          "@id": "https://podcastnetwork.org/the-package/#offer",
          "price": "30000.00",
          "priceCurrency": "USD",
          "availability": "https://schema.org/LimitedAvailability",
          "seller": { "@id": "https://podcastnetwork.org/#organization" }
        },
        {
          "@type": "FAQPage",
          "@id": "https://podcastnetwork.org/the-package/#faq-package",
          "mainEntity": [
            { "@id": "https://podcastnetwork.org/faq/#what-does-30k-cover" },
            { "@id": "https://podcastnetwork.org/faq/#six-months-not-24" },
            { "@id": "https://podcastnetwork.org/faq/#manuscript-in-hand" },
            { "@id": "https://podcastnetwork.org/faq/#no-podcast-yet" },
            { "@id": "https://podcastnetwork.org/faq/#legacy-jv" },
            { "@id": "https://podcastnetwork.org/faq/#knowledge-panel-mechanics" },
            { "@id": "https://podcastnetwork.org/faq/#pre-sold-audience-mechanics" },
            { "@id": "https://podcastnetwork.org/faq/#payment-terms" },
            { "@id": "https://podcastnetwork.org/faq/#refund" },
            { "@id": "https://podcastnetwork.org/faq/#what-if-i-slip" },
            { "@id": "https://podcastnetwork.org/faq/#versus-diy" },
            { "@id": "https://podcastnetwork.org/faq/#application-timeline" }
          ]
        },
        {
          "@type": "BreadcrumbList",
          "@id": "https://podcastnetwork.org/the-package/#breadcrumb",
          "itemListElement": [
            { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://podcastnetwork.org/" },
            { "@type": "ListItem", "position": 2, "name": "The Pre-Sold Author Package", "item": "https://podcastnetwork.org/the-package/" }
          ]
        }
      ]
    },


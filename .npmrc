# The Client Portal v0.2 build adds @supabase/ssr and @supabase/supabase-js.
# Until a maintainer runs `pnpm install` locally and commits the refreshed
# lockfile, allow Vercel's install step to update pnpm-lock.yaml on the fly
# instead of failing with ERR_PNPM_OUTDATED_LOCKFILE.
frozen-lockfile=false
